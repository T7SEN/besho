generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CountdownEvent {
  id          String   @id @default(cuid())
  title       String   
  targetDate  DateTime
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ping {
  id          String   @id @default(cuid())
  senderAlias String   
  hasBeenSeen Boolean  @default(false)
  createdAt   DateTime @default(now())
}